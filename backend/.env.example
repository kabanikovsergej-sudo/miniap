# Core server
NODE_ENV=production
PORT=10000
JWT_SECRET=replace_with_a_long_random_secret

# Existing Supabase project (service role stays on the server only)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_with_service_role_key

# Telegram — never copy this token into Vite/frontend variables
TELEGRAM_BOT_TOKEN=123456:replace_me
TELEGRAM_MINI_APP_URL=https://app.example.com
APP_WEB_ORIGIN=https://app.example.com
CORS_ORIGINS=https://app.example.com
TELEGRAM_INITDATA_MAX_AGE_SECONDS=86400

# Optional: use a webhook in production; omit to use long polling locally.
TELEGRAM_WEBHOOK_URL=https://api.example.com
TELEGRAM_WEBHOOK_PATH=/telegram/webhook
