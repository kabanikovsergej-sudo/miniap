{
  "name": "nightcorex-telegram-mini-app",
  "private": true,
  "version": "2.0.0",
  "description": "NightCoreX Telegram Mini App frontend",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "backend": "npm --prefix backend run dev",
    "dev:all": "concurrently \"npm run dev\" \"npm run backend\"",
    "check": "npm run build"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.89.0",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.24.0",
    "lucide-react": "^0.562.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-icons": "^5.5.0",
    "react-is": "^19.2.7",
    "react-router-dom": "^7.11.0",
    "recharts": "^3.6.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.2",
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.2.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "vite": "^7.2.4"
  }
}
